.roadmap-section {
  padding: 80px 0;
  background: linear-gradient(90deg, #d8e8f4 0%, #edf0f7 50%, #d9f2ff 100%);
  position: relative;
  overflow: hidden;
}
.roadmap-section .roadmap-image {
  padding-right: 20px;
}
.roadmap-section .roadmap-image img {
  width: 100%;
  max-width: 360px;
  height: auto;
  border-radius: 24px;
}
.roadmap-section .roadmap-content .roadmap-title {
  font-size: clamp(22px, 5vw, 32px);
  font-weight: 700;
  margin-bottom: 15px;
  line-height: 1.2;
}
.roadmap-section .roadmap-content .roadmap-description {
  font-size: clamp(16px, 1.5vw, 16px);
  margin-bottom: 40px;
  max-width: 900px;
  line-height: 1.6;
}
.roadmap-section .roadmap-slider {
  position: relative;
  padding-bottom: 5px;
  border-bottom: 3px solid #474CB5;
}
.roadmap-section .roadmap-slider .owl-stage {
  display: flex;
}
.roadmap-section .roadmap-slider .owl-item {
  height: auto;
}
.roadmap-section .roadmap-slider .owl-item:nth-child(3n+1) .roadmap-step-item::after {
  background: #009cff;
}
.roadmap-section .roadmap-slider .owl-item:nth-child(3n+2) .roadmap-step-item::after {
  background: #ff2e93;
}
.roadmap-section .roadmap-slider .owl-item:nth-child(3n+3) .roadmap-step-item::after {
  background: #7a43ff;
}
.roadmap-section .roadmap-slider .roadmap-step-item {
  padding-bottom: 35px;
  position: relative;
  height: 100%;
  transition: all 0.3s ease;
}
.roadmap-section .roadmap-slider .roadmap-step-item .step-number {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background: linear-gradient(180deg, #8fd9ff 0%, #57a9ff 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: clamp(20px, 2vw, 24px);
  font-weight: 700;
  color: #fff;
  margin-bottom: 24px;
  box-shadow: 0 4px 10px rgba(87, 169, 255, 0.3);
}
@media (max-width: 1199px) {
  .roadmap-section .roadmap-slider .roadmap-step-item .step-number {
    width: 44px;
    height: 44px;
  }
}
@media (max-width: 576px) {
  .roadmap-section .roadmap-slider .roadmap-step-item .step-number {
    width: 40px;
    height: 40px;
    margin-bottom: 18px;
  }
}
.roadmap-section .roadmap-slider .roadmap-step-item .step-title {
  font-size: clamp(18px, 2vw, 22px);
  font-weight: 700;
  color: #1b1b1b;
  margin-bottom: 12px;
}
.roadmap-section .roadmap-slider .roadmap-step-item .step-description {
  font-size: clamp(15px, 1.5vw, 17px);
  color: #555;
  margin-bottom: 0;
}
.roadmap-section .roadmap-slider .owl-nav {
  position: absolute;
  bottom: -70px;
  right: 0;
  display: flex;
  gap: 15px;
}
@media (max-width: 991px) {
  .roadmap-section .roadmap-slider .owl-nav {
    bottom: -60px;
  }
}
.roadmap-section .roadmap-slider .owl-nav button.owl-prev,
.roadmap-section .roadmap-slider .owl-nav button.owl-next {
  width: 50px;
  height: 50px;
  border-radius: 50%;
  background-color: #5c4eff !important;
  color: #ffffff !important;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  border: none;
  transition: all 0.3s ease;
  box-shadow: 0 4px 10px rgba(92, 78, 255, 0.3);
}
.roadmap-section .roadmap-slider .owl-nav button.owl-prev.disabled,
.roadmap-section .roadmap-slider .owl-nav button.owl-next.disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}
@media (max-width: 991px) {
  .roadmap-section .roadmap-slider .owl-nav button.owl-prev,
  .roadmap-section .roadmap-slider .owl-nav button.owl-next {
    width: 40px;
    height: 40px;
    font-size: 16px;
  }
}

.ai-hero-section {
