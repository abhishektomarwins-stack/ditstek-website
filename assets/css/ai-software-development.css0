.ai-cost-section .cost-wrapper {
  padding: clamp(15px, 4vw, 48px);
  border-radius: 15px;
  background: rgba(255, 255, 255, 0.4);
}
.ai-cost-section .cost-wrapper .cost-card {
  padding: clamp(20px, 3.5vw, 32px);
  border-radius: 16px;
