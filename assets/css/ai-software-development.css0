/* Compact Header Toggle - SCSS Version */
@font-face {
  font-family: "Red Hat Display";
  src: url("../fonts/RedHatDisplay-Light.woff2") format("woff2"), url("../fonts/RedHatDisplay-Light.woff") format("woff");
  font-weight: 300;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: "Red Hat Display";
  src: url("../fonts/RedHatDisplay-Regular.woff2") format("woff2"), url("../fonts/RedHatDisplay-Regular.woff") format("woff");
  font-weight: 400;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: "Red Hat Display";
  src: url("../fonts/RedHatDisplay-Medium.woff2") format("woff2"), url("../fonts/RedHatDisplay-Medium.woff") format("woff");
  font-weight: 500;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: "Red Hat Display";
  src: url("../fonts/RedHatDisplay-SemiBold.woff2") format("woff2"), url("../fonts/RedHatDisplay-SemiBold.woff") format("woff");
  font-weight: 600;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: "Red Hat Display";
  src: url("../fonts/RedHatDisplay-Bold.woff2") format("woff2"), url("../fonts/RedHatDisplay-Bold.woff") format("woff");
  font-weight: 700;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: "Red Hat Display";
  src: url("../fonts/RedHatDisplay-ExtraBold.woff2") format("woff2"), url("../fonts/RedHatDisplay-ExtraBold.woff") format("woff");
  font-weight: 800;
  font-style: normal;
  font-display: swap;
}
@font-face {
  font-family: "Red Hat Display";
  src: url("../fonts/RedHatDisplay-Black.woff2") format("woff2"), url("../fonts/RedHatDisplay-Black.woff") format("woff");
  font-weight: 900;
  font-style: normal;
  font-display: swap;
}
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  width: 100%;
  max-width: 100vw;
  overflow-x: clip;
}

body {
  font-family: "Red Hat Display", sans-serif;
  padding-top: 90px;
}

section {
  overflow-x: hidden;
}

.benefits-section {
  overflow-x: visible !important;
}

.services-section {
  background: #F4F9FD;
  padding: 80px 0;
}
@media (max-width: 991px) {
  .services-section {
    padding: 60px 0;
  }
}
@media (max-width: 767px) {
  .services-section {
    padding: 40px 0;
  }
}
.services-section h2 {
  color: #193370;
  font-size: clamp(24px, 4.5vw, 36px);
}
@media (max-width: 567px) {
  .services-section h2 {
    text-align: left !important;
  }
}
.services-section p {
  width: 100%;
  max-width: 850px;
  font-size: clamp(14px, 2vw, 16px);
}
@media (max-width: 567px) {
  .services-section p {
    text-align: left !important;
  }
}
.services-section .service-card {
  background: #1d377d;
  color: #fff;
  border-radius: 8px;
  padding: 35px;
  width: 410px;
  max-width: 100%;
  margin: 0 auto;
  height: 100%;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  transition: all 0.3s ease;
}
@media (max-width: 991px) {
  .services-section .service-card {
    width: 100%;
  }
}
@media (max-width: 767px) {
  .services-section .service-card {
    padding: 25px;
  }
}
@media (max-width: 567px) {
  .services-section .service-card {
    padding: 20px;
  }
}
.services-section .service-card h3 {
  font-size: clamp(20px, 2.5vw, 26px);
  font-weight: 700;
  margin-bottom: 16px;
}
.services-section .service-card p {
  font-size: clamp(14px, 1.5vw, 15px);
  max-width: 100%;
}
.services-section .services-slider {
  position: relative;
}
@media (max-width: 991px) {
  .services-section .services-slider {
    padding: 0 10px;
  }
}
.services-section .services-slider .owl-stage-outer {
  padding: 30px 0;
  margin: -30px 0;
}
.services-section .services-slider .owl-stage {
  display: flex !important;
}
.services-section .services-slider .owl-item {
  display: flex !important;
  flex-direction: column;
}
.services-section .services-slider .owl-item .service-card {
  transform: scale(0.9);
  opacity: 0.5;
  transition: all 0.4s ease;
}
@media (max-width: 991px) {
  .services-section .services-slider .owl-item .service-card {
    transform: scale(1);
    opacity: 1;
  }
}
.services-section .services-slider .owl-item.center .service-card {
  transform: scale(1.05);
  opacity: 1;
  border-radius: 10px !important;
}
@media (max-width: 991px) {
  .services-section .services-slider .owl-item.center .service-card {
    transform: scale(1);
  }
}
.services-section .services-slider .owl-dots {
  margin-top: 30px;
  text-align: center;
}
@media (max-width: 767px) {
  .services-section .services-slider .owl-dots {
    margin-top: 20px;
  }
}
.services-section .services-slider .owl-dot {
  background: none !important;
  border: none !important;
  padding: 0 !important;
  outline: none !important;
  display: inline-block;
}
.services-section .services-slider .owl-dot span {
  width: 40px;
  height: 4px;
  margin: 5px;
  background: #c8d8f0;
  display: block;
  transition: all 0.3s ease;
  border-radius: 2px;
}
@media (max-width: 767px) {
  .services-section .services-slider .owl-dot span {
    width: 15px;
    margin: 3px;
  }
}
.services-section .services-slider .owl-dot.active span {
  background: #1d377d;
}
@media (max-width: 767px) {
  .services-section .services-slider .owl-dot.active span {
    width: 30px;
  }
}
@media (max-width: 991px) {
  .services-section .services-slider .owl-nav {
    display: none !important;
  }
}
.services-section .services-slider .owl-nav button.owl-prev,
.services-section .services-slider .owl-nav button.owl-next {
  position: absolute;
  top: 45%;
  transform: translateY(-50%);
  width: 46px;
  height: 46px;
  border-radius: 50% !important;
  background: #ffffff !important;
  align-items: center;
  justify-content: center;
  display: flex;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
}
.services-section .services-slider .owl-nav button.owl-prev i,
.services-section .services-slider .owl-nav button.owl-next i {
  font-size: 20px;
  font-weight: normal;
}
.services-section .services-slider .owl-nav button.owl-prev:hover,
.services-section .services-slider .owl-nav button.owl-next:hover {
  background: #193370 !important;
  color: #ffffff !important;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.25) !important;
}
.services-section .services-slider .owl-nav button.owl-prev.disabled,
.services-section .services-slider .owl-nav button.owl-next.disabled {
  opacity: 0.5;
  cursor: not-allowed;
}
.services-section .services-slider .owl-nav button.owl-prev {
  left: 29px;
}
.services-section .services-slider .owl-nav button.owl-next {
  right: 29px;
}

.benefit-Section .section-title {
  color: #194a8d;
  max-width: 700px;
}
@media (max-width: 567px) {
  .benefit-Section .section-title {
    text-align: left !important;
  }
}
.benefit-Section .benefit-card {
  flex: 1;
  cursor: pointer;
}
@media (max-width: 1199px) {
  .benefit-Section .benefit-card {
    flex: 0 0 calc(50% - 10px);
    min-height: 285px;
  }
}
@media (max-width: 767px) {
  .benefit-Section .benefit-card {
    flex: 0 0 100%;
    min-height: 285px;
  }
}
@media (min-width: 1200px) {
  .benefit-Section .benefit-card {
    height: 360px;
    transition-duration: 1s;
    transition-timing-function: cubic-bezier(0.62, 0.15, 0.85, 1.04);
  }
  .benefit-Section .benefit-card.active {
    flex-grow: 2;
  }
  .benefit-Section .benefit-card.active .vertical-text {
    writing-mode: vertical-rl;
    transform: rotate(-90deg) translateY(50%);
    transform-origin: center;
  }
  .benefit-Section .benefit-card:not(.active) .vertical-text {
    writing-mode: vertical-rl;
    transform: rotate(-180deg);
    transform-origin: center;
  }
}
.benefit-Section .benefit-card::before {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 0%, rgba(0, 0, 0, 0.6) 100%);
  z-index: 1;
}
@media (max-width: 1199px) {
  .benefit-Section .benefit-card::before {
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.7) 100%);
  }
}
.benefit-Section .benefit-card .card-content {
  position: relative;
  z-index: 2;
}
.benefit-Section .benefit-card .vertical-text {
  color: #ffffff !important;
  -webkit-text-fill-color: #ffffff !important;
  -webkit-text-stroke: 0 !important;
  opacity: 1 !important;
}
@media (min-width: 1200px) {
  .benefit-Section .benefit-card .vertical-text {
    transition-duration: 1s;
    transition-timing-function: cubic-bezier(0.62, 0.15, 0.85, 1.04);
  }
}
.benefit-Section .content-box {
  display: none;
  transition: all 0.5s;
}
.benefit-Section .content-box.active {
  display: block;
}
.benefit-Section .content-box h3 {
  color: #193370;
}

.tech-section {
  background: #F4F4F4;
  padding: 50px 0;
  overflow: hidden;
}
.tech-section .section-heading {
  color: #193370;
  font-size: clamp(24px, 4.5vw, 30px);
}
.tech-section .tech-slider .owl-stage {
  display: flex !important;
  align-items: center;
}
.tech-section .tech-slider .owl-item {
  display: flex !important;
  justify-content: center;
}
.tech-section .tech-card {
  width: 100%;
  max-width: 160px;
  height: 80px;
}
.tech-section .tech-card img {
  max-height: 55px;
  width: auto !important;
  max-width: 85%;
}

.hero-btn {
  background: #007bff;
  color: #fff;
  border-radius: 8px;
  font-weight: 700;
  padding: 15px 40px;
  border: 1px solid transparent;
  transition: all 0.3s ease;
}
@media (max-width: 991px) {
  .hero-btn {
    padding: 14px 50px;
  }
}
@media (max-width: 575px) {
  .hero-btn {
    padding: 14px 30px;
    width: 100%;
    display: block;
    text-align: center;
    justify-content: center;
  }
}

.hero-btn-white {
  background: #fff;
  color: #193370;
  border-radius: 8px;
  font-weight: 700;
  text-decoration: none;
  padding: 15px 50px;
  transition: all 0.3s ease;
}
.hero-btn-white:hover {
  background: #007bff;
  color: #fff;
}
@media (max-width: 991px) {
  .hero-btn-white {
    padding: 15px 60px;
  }
}
@media (max-width: 575px) {
  .hero-btn-white {
    padding: 15px 30px;
    width: 100%;
    display: block;
    text-align: center;
  }
}

@keyframes scroll-marquee {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}
.marquee-wrapper {
  background: #fff;
  border-top: 1px solid rgba(0, 0, 0, 0.08);
  border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  padding: 24px 0;
  overflow: hidden;
  width: 100%;
}
.marquee-wrapper .marquee-track {
  display: flex;
  align-items: center;
  width: max-content;
  --gap: 120px;
  gap: var(--gap);
  padding-right: var(--gap);
  animation: scroll-marquee 20s linear infinite;
}
@media (max-width: 991px) {
  .marquee-wrapper .marquee-track {
    --gap: 60px;
  }
}
@media (max-width: 576px) {
  .marquee-wrapper .marquee-track {
    --gap: 30px;
  }
}
.marquee-wrapper .marquee-track img {
  height: 90px;
  width: auto;
  object-fit: contain;
  display: block;
}
@media (max-width: 991px) {
  .marquee-wrapper .marquee-track img {
    height: 60px;
  }
}
@media (max-width: 576px) {
  .marquee-wrapper .marquee-track img {
    height: 40px;
  }
}

.solution-cta {
  margin-top: -60px;
}
@media (max-width: 991px) {
  .solution-cta {
    margin-top: -40px;
  }
}
.solution-cta .cta-wrapper {
  padding: 44px 0 44px 60px;
  border-radius: 18px;
  background: url("../images/ai-software/custom-bg.webp") center/cover no-repeat;
}
@media (max-width: 991px) {
  .solution-cta .cta-wrapper {
    padding: 40px 30px;
  }
}
.solution-cta .cta-content {
  max-width: 470px;
}
@media (max-width: 991px) {
  .solution-cta .cta-content {
    max-width: 100%;
    text-align: center;
  }
}
.solution-cta .cta-content h3 {
  font-size: 26px;
  font-weight: 700;
  color: #222222;
  margin-bottom: 16px;
  line-height: 1.3;
}
.solution-cta .cta-content p {
  font-size: 15px;
  color: #444444;
  margin-bottom: 24px;
  line-height: 1.6;
}
.solution-cta .right-img {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 100%;
  max-width: 450px;
  height: 100%;
  object-fit: contain;
  object-position: bottom right;
}
@media (max-width: 991px) {
  .solution-cta .right-img {
    display: none;
  }
}

.lets-talk-banner {
  background: #162a56 url("../images/home-page/lets-talk.webp") center center/100% auto no-repeat;
  border-radius: 15px;
}
@media (max-width: 1200px) {
  .lets-talk-banner {
    background-size: cover;
  }
}
@media (max-width: 767px) {
  .lets-talk-banner {
    border-radius: 10px;
    background-image: none;
  }
}
.lets-talk-banner .banner-title {
  max-width: 820px;
  font-size: clamp(22px, 4vw, 31px);
  line-height: 1.4;
}
@media (max-width: 767px) {
  .lets-talk-banner .banner-title {
    margin-bottom: 1.5rem !important;
    padding: 10px;
  }
}
@media (max-width: 767px) {
  .lets-talk-banner p {
    padding: 10px;
  }
}
.lets-talk-banner .btn-lets-talk {
  background: #ffffff;
  padding: 12px 100px;
  color: #162a56;
  transition: all 0.3s ease;
}
.lets-talk-banner .btn-lets-talk:hover {
  background: #e2e6ea;
  transform: translateY(-2px);
}
@media (max-width: 767px) {
  .lets-talk-banner .btn-lets-talk {
    padding: 12px 50px;
    width: 100%;
    max-width: 280px;
  }
}

.start-your-dream {
  background: linear-gradient(180deg, rgba(32, 41, 44, 0) 0%, #000000 100%), url(../images/ai-software/start-your-dream.png);
  background-size: cover;
  background-repeat: no-repeat;
  background-position: center;
  padding: 173px 0;
}
@media (max-width: 767px) {
  .start-your-dream {
    padding: 60px 0;
  }
}
.start-your-dream h2 {
  font-size: 100px;
  margin: auto;
  max-width: 840px;
  text-align: center;
  background: radial-gradient(100.97% 265.86% at 110.31% -37.64%, #fab8ff 0%, #ffffff 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
@media (max-width: 991px) {
  .start-your-dream h2 {
    font-size: 60px;
    text-align: left;
    margin: 0;
  }
}
@media (max-width: 767px) {
  .start-your-dream h2 {
    font-size: 40px !important;
  }
}

.development-partner {
  padding: 90px 0;
  background-color: #000000;
  overflow: visible !important;
}
@media (max-width: 767px) {
  .development-partner {
    padding: 45px 0;
  }
}
.development-partner .development-firm-carousel {
  padding-top: 110px;
}
.development-partner .development-firm-carousel ul {
  list-style: none;
  padding: 0;
  margin: 0;
  position: relative;
}
.development-partner .development-firm-carousel ul .development-list {
  background: #222222;
  padding: 40px 40px 0px;
  border-radius: 18px;
  margin-bottom: 20px;
  cursor: pointer;
  transition: all 0.5s;
  position: sticky;
  z-index: 1;
  display: flex;
  align-items: start;
  gap: 15px;
}
.development-partner .development-firm-carousel ul .development-list:nth-child(1) {
  top: 116px;
  z-index: 1;
}
.development-partner .development-firm-carousel ul .development-list:nth-child(2) {
  top: 132px;
  z-index: 2;
}
.development-partner .development-firm-carousel ul .development-list:nth-child(3) {
  top: 148px;
  z-index: 3;
}
.development-partner .development-firm-carousel ul .development-list:nth-child(4) {
  top: 164px;
  z-index: 4;
}
.development-partner .development-firm-carousel ul .development-list:last-child {
  margin: 0;
}
@media (max-width: 767px) {
  .development-partner .development-firm-carousel ul .development-list {
    flex-direction: column;
    position: static;
    padding: 20px 25px;
  }
}
.development-partner .development-firm-carousel ul .development-list .development-content {
  max-width: 540px;
}
@media (max-width: 991px) {
  .development-partner .development-firm-carousel ul .development-list .development-content {
    max-width: 340px;
  }
}
@media (max-width: 767px) {
  .development-partner .development-firm-carousel ul .development-list .development-content {
    max-width: 100%;
  }
}
.development-partner .development-firm-carousel ul .development-list .development-content h3 {
  font-weight: 700;
  color: #fff;
  margin-bottom: 11px;
}
@media (max-width: 575px) {
  .development-partner .development-firm-carousel ul .development-list .development-content h3 {
    font-size: 18px;
  }
}
.development-partner .development-firm-carousel ul .development-list .development-content p {
  color: #fff;
}

.hero-section {
  position: relative;
  min-height: calc(100vh - 90px);
  display: flex;
  align-items: center;
}
@media (max-width: 991px) {
  .hero-section {
    height: auto;
    padding: 60px 0;
  }
}
.hero-section .hero-video-bg {
  object-fit: cover;
}
.hero-section h1 {
  font-size: clamp(32px, 5vw, 55px);
  margin-bottom: 22px;
  line-height: 1.2;
}
@media (max-width: 576px) {
  .hero-section h1 {
    margin-bottom: 16px;
  }
}
.hero-section p {
  font-size: clamp(16px, 1.5vw, 16px);
  max-width: 590px;
  margin-bottom: 32px;
  line-height: 1.6;
}
@media (max-width: 991px) {
  .hero-section p {
    max-width: 100%;
    margin-bottom: 24px;
  }
}
.hero-section .hero-visual {
  display: flex;
  justify-content: flex-end;
  align-items: center;
}
.hero-section .hero-visual img {
  max-height: 80vh;
  object-fit: contain;
  transform: scale(1.15);
  transform-origin: right center;
}
@media (max-width: 991px) {
  .hero-section .hero-visual {
    justify-content: center;
    margin-top: 30px;
  }
  .hero-section .hero-visual img {
    max-height: 50vh;
    transform: none;
  }
}

.who-section {
  background: url("../images/ai-software/who-bg.webp") center/cover no-repeat;
}
.who-section .who-badge {
  background: #ffffff;
  border-radius: 25px;
  font-size: 18px;
  font-weight: 500;
  padding: 8px 24px;
  color: #3958BD;
}
.who-section .who-heading {
  font-size: clamp(26px, 4vw, 36px);
  color: #333333;
  margin-bottom: 50px;
}
@media (max-width: 991px) {
  .who-section .who-heading {
    margin-bottom: 36px;
  }
}
.who-section .who-stat {
  padding: 28px 24px;
  border-right: 1px solid rgba(0, 0, 0, 0.08);
  border-bottom: none;
}
@media (max-width: 991px) {
  .who-section .who-stat {
    align-items: center;
    text-align: center !important;
    padding: 24px 16px !important;
    border-right: none !important;
    border-bottom: 2px solid rgba(0, 0, 0, 0.08);
  }
}
.who-section .who-stat-icon {
  display: flex;
  margin-bottom: 12px;
}
.who-section .who-stat-icon img {
  height: 48px;
  width: auto;
  object-fit: contain;
  transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
}
@media (max-width: 991px) {
  .who-section .who-stat-icon img {
    height: 42px;
  }
}
.who-section .who-stat-number {
  font-size: clamp(28px, 4.5vw, 42px);
  background: linear-gradient(180deg, #1868d0 0%, #c157f2 100%);
  background-clip: text;
  text-align: left;
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}
@media (max-width: 991px) {
  .who-section .who-stat-number {
    text-align: center;
  }
}
.who-section .who-stat-label {
  max-width: 200px;
  font-size: clamp(10px, 1.5vw, 16px);
  text-align: left;
  color: #444444;
}
@media (max-width: 991px) {
  .who-section .who-stat-label {
    max-width: 100%;
    text-align: center;
  }
}
.who-section .who-cta {
  margin-top: 40px;
  padding: 24px 30px;
  background: #325C80;
  border-radius: 12px;
}
