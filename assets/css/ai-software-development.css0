  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  transition: all 0.3s ease;
  outline: none;
}
.industry-section .industry-carousel .owl-nav button.owl-prev:hover,
.industry-section .industry-carousel .owl-nav button.owl-next:hover {
  background: rgba(255, 255, 255, 0.1) !important;
}
.industry-section .industry-carousel .owl-nav button.owl-prev i,
.industry-section .industry-carousel .owl-nav button.owl-next i {
